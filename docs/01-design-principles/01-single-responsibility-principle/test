--- 流程类 ---
class OrderManager {
    private 用户信息检查类 userCheck;
    private 商品检查类 itemCheck;

    private OrderMapper orderMapper;
    private ProductMapper productMapper;

    private SendEmail sendEmail;
    private SendText sendText;
    private RecordLog recordLog;

    private 发票类 发票类;
    private sendSystem sendSystem

    createOrder()
    payOrder()

    createOrder(User user, List<product> productItems) {

        if (!userCheck.检查用户信息(user.userId)) {
            return
        }

        for i : 商品列表:
            if (!itemCheck.isStock(i) || !itemCheck.isPrice(i)) return

        Order order = new Order(填充信息)

        orderMapper.saveOrder(order)

        for i : 商品列表:
            productMapper.reduceStock(i)

        sendEmail.sendEmail();

        recordLog.recordLog();

        return
    }

    payOrder(Order order) {


        OrderMapper.updateOrderState(order.orderId);
        发票类.生成发票();
        sendSystem.sendLogisticsSystem();
        sendText.sendText();
    }
}






























